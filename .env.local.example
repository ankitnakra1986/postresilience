# Copy this file to .env.local and fill in your values.
# All variables are optional — the app runs in demo mode without them.

# AWS Bedrock — enables Claude-powered voice extraction
# Without this, falls back to keyword heuristic (still fully functional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Mappls (MapmyIndia) — enables Indian map tiles
# Without this, falls back to OpenStreetMap (still works)
# Get your key at: https://auth.mappls.com/console
NEXT_PUBLIC_MAPPLS_KEY=

# Demo mode — set to true to pre-load mock Kerala flood data
NEXT_PUBLIC_DEMO_MODE=false
